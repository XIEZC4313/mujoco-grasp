<mujoco model="grasp_scene">
  <include file="robot.xml"/>

  <visual>
    <global offwidth="1280" offheight="720"/>
  </visual>

  <worldbody>
    <!-- Table (further from arm, smaller) -->
    <body name="table" pos="0.35 0 0.15">
      <geom name="table_top" size="0.15 0.15 0.015" type="box" rgba="0.6 0.4 0.2 1" condim="4" friction="1 0.5 0.01"/>
      <geom name="table_leg1" fromto="0.1 0.1 -0.015 0.1 0.1 -0.135" size="0.015" type="cylinder" rgba="0.5 0.3 0.1 1"/>
      <geom name="table_leg2" fromto="0.1 -0.1 -0.015 0.1 -0.1 -0.135" size="0.015" type="cylinder" rgba="0.5 0.3 0.1 1"/>
      <geom name="table_leg3" fromto="-0.1 0.1 -0.015 -0.1 0.1 -0.135" size="0.015" type="cylinder" rgba="0.5 0.3 0.1 1"/>
      <geom name="table_leg4" fromto="-0.1 -0.1 -0.015 -0.1 -0.1 -0.135" size="0.015" type="cylinder" rgba="0.5 0.3 0.1 1"/>
    </body>

    <!-- 3 colored blocks: red, green, blue -->
    <body name="red_block" pos="0.33 0.08 0.19">
      <freejoint name="red_block_joint"/>
      <geom name="red_geom" size="0.015 0.015 0.015" type="box" rgba="1 0 0 1" mass="0.01" condim="4" friction="3 0.5 0.01" conaffinity="1"/>
    </body>

    <body name="green_block" pos="0.36 0.0 0.19">
      <freejoint name="green_block_joint"/>
      <geom name="green_geom" size="0.015 0.015 0.015" type="box" rgba="0 1 0 1" mass="0.01" condim="4" friction="3 0.5 0.01" conaffinity="1"/>
    </body>

    <body name="blue_block" pos="0.33 -0.08 0.19">
      <freejoint name="blue_block_joint"/>
      <geom name="blue_geom" size="0.015 0.015 0.015" type="box" rgba="0 0 1 1" mass="0.01" condim="4" friction="3 0.5 0.01" conaffinity="1"/>
    </body>

    <!-- Target location for placing green block -->
    <body name="target" pos="0.4 -0.12 0.17">
      <geom name="target_geom" size="0.04 0.04 0.005" type="cylinder" rgba="0.8 0.8 0.8 0.3" contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
