<mujoco model="5dof_arm">
  <compiler angle="radian" autolimits="true"/>

  <default>
    <joint armature="0.1" damping="3" limited="true"/>
    <geom condim="4" friction="5 0.5 0.01" conaffinity="1"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <asset>
    <texture builtin="gradient" height="100" rgb1="0.8 0.6 0.4" rgb2="0.6 0.4 0.2" type="skybox" width="100"/>
    <texture builtin="checker" height="100" name="texplane" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" type="2d" width="100"/>
    <material name="MatPlane" reflectance="0.5" shininess="1" specular="1" texrepeat="60 60" texture="texplane"/>
  </asset>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom conaffinity="1" condim="3" material="MatPlane" name="floor" pos="0 0 0" size="0 0 0.05" type="plane"/>

    <body name="base" pos="0 0 0.05">
      <geom fromto="0 0 0 0 0 0.08" name="base_link" size="0.06" type="cylinder" rgba="0.2 0.2 0.8 1"/>

      <body name="link1" pos="0 0 0.08">
        <joint axis="0 0 1" name="joint1" range="-3.14 3.14" type="hinge"/>
        <geom fromto="0 0 0 0 0 0.08" name="link1_geom" size="0.04" type="cylinder" rgba="0.8 0.2 0.2 1"/>

        <body name="link2" pos="0 0 0.08">
          <joint axis="0 1 0" name="joint2" range="-1.8 1.8" type="hinge"/>
          <geom fromto="0 0 0 0.25 0 0" name="link2_geom" size="0.035" type="cylinder" rgba="0.2 0.8 0.2 1"/>

          <body name="link3" pos="0.25 0 0">
            <joint axis="0 1 0" name="joint3" range="-3.0 3.0" type="hinge"/>
            <geom fromto="0 0 0 0.2 0 0" name="link3_geom" size="0.03" type="cylinder" rgba="0.2 0.2 0.8 1"/>

            <body name="link4" pos="0.2 0 0">
              <joint axis="1 0 0" name="joint4" range="-2.0 2.0" type="hinge"/>
              <geom fromto="0 0 0 0 0 0.06" name="link4_geom" size="0.025" type="cylinder" rgba="0.8 0.8 0.2 1"/>

              <body name="link5" pos="0 0 0.06">
                <joint axis="0 0 1" name="joint5" range="-3.14 3.14" type="hinge"/>
                <geom fromto="0 0 0 0 0 0.03" name="link5_geom" size="0.02" type="cylinder" rgba="0.8 0.2 0.8 1"/>

                <!-- Gripper: two fingers slide along y-axis (perpendicular to arm) -->
                <body name="gripper_base" pos="0 0 0.03">
                  <geom name="gripper_base_geom" size="0.02 0.015 0.01" type="box" rgba="0.5 0.5 0.5 1"/>

                  <!-- Left finger: slides in +y direction, geom extends inward -->
                  <body name="left_finger" pos="0 0.012 0">
                    <joint axis="0 1 0" name="finger_left" range="-0.005 0.025" type="slide"/>
                    <geom name="left_finger_geom" pos="0 0.003 0" size="0.015 0.009 0.01" type="box" rgba="0.9 0.9 0.9 1"/>
                  </body>

                  <!-- Right finger: slides in -y direction, geom extends inward -->
                  <body name="right_finger" pos="0 -0.012 0">
                    <joint axis="0 1 0" name="finger_right" range="-0.025 0.005" type="slide"/>
                    <geom name="right_finger_geom" pos="0 -0.003 0" size="0.015 0.009 0.01" type="box" rgba="0.9 0.9 0.9 1"/>
                  </body>

                  <!-- End effector site at gripper center -->
                  <site name="end_effector" pos="0 0 0" size="0.005"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor gear="50" joint="joint1" name="act_joint1"/>
    <motor gear="50" joint="joint2" name="act_joint2"/>
    <motor gear="30" joint="joint3" name="act_joint3"/>
    <motor gear="20" joint="joint4" name="act_joint4"/>
    <motor gear="10" joint="joint5" name="act_joint5"/>
    <motor gear="50" joint="finger_left" name="act_finger_left"/>
    <motor gear="50" joint="finger_right" name="act_finger_right"/>
  </actuator>
</mujoco>
